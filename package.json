    "check": "npm run typecheck && npm run test",
    "types:worker": "npm exec -- wrangler types"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "agents": "0.13.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7",
    "wrangler": "4.93.0"
  },
  "overrides": {
    "ws": "^8.20.1"
  }
}
