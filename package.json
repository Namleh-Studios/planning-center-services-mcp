{
  "name": "planning-center-services-mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "A Cloudflare Workers MCP server for Planning Center Services scheduling workflows.",
  "license": "MIT",
  "scripts": {
    "dev": "npm exec -- wrangler dev",
    "deploy": "npm exec -- wrangler deploy",
